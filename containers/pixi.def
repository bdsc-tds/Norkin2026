Bootstrap: docker
From: ubuntu:22.04

%files
    # Copy your manifest files to /app
    pixi.toml /app/pixi.toml
    pixi.lock /app/pixi.lock

%post
    # 1. Install system basics
    apt-get update && apt-get install -y curl git build-essential locales
    
    # Set locales to avoid python encoding issues
    locale-gen en_US.UTF-8
    
    # 2. Install Pixi globally
    export PIXI_HOME=/opt/pixi
    curl -fsSL https://pixi.sh/install.sh | bash
    # Move pixi bin to a global location so it's always found
    ln -s /opt/pixi/bin/pixi /usr/local/bin/pixi

    # 3. Install all environments
    cd /app
    pixi config set --local run-post-link-scripts insecure
    CONDA_OVERRIDE_CUDA=12.0 pixi install --frozen --all
    
    # Clean up apt
    rm -rf /var/lib/apt/lists/*

%environment
    # 1. Set Locale
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8

    # 2. Point Pixi to the project root
    # This ensures pixi knows where the .pixi folder is when you run commands
    export PIXI_PROJECT_MANIFEST="/app/pixi.toml"

    # 3. GLOBAL REPRODUCIBILITY SETTINGS
    # These apply to ALL environments (cpu, gpu, default)
    
    # Force generic CPU instructions (fixes the Node A vs Node B PCA issue)
    export NUMBA_CPU_NAME="generic"
    
    # Force Single Threading for deterministic Linear Algebra
    export MKL_NUM_THREADS="1"
    export OPENBLAS_NUM_THREADS="1"
    export OMP_NUM_THREADS="1"
    export VECLIB_MAXIMUM_THREADS="1"
    export NUMBA_NUM_THREADS="1"

    # Python Hashing
    export PYTHONHASHSEED="0"
    
    # PyTorch Determinism (scVI)
    export CUBLAS_WORKSPACE_CONFIG=":4096:8"

%runscript
    # Default behavior: pass commands through
    # This allows you to run: apptainer run image.sif pixi run -e my_env python script.py
    exec "$@"